{
  "name": "Instant Print Orders",
  "description": "Instant Print Tokopedia & Shopee Orders (© 2026 Hela Dixman, CC BY-NC)",
  "version": "1.1.0",
  "manifest_version": 3,
  "permissions": ["notifications", "scripting", "activeTab", "commands", "storage"],
  "author": "Hela Dixman",

  "icons": {
    "16": "assets/icons/icon-16.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },

  "content_scripts": [
    {
      "matches": ["https://seller-id.tokopedia.com/order/*"],
      "js": ["assets/js/tokopedia.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://seller.shopee.co.id/portal/sale/order/*"],
      "js": ["assets/js/shopee.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "assets/pages/index.html"
  },

  "background": {
    "service_worker": "background.js"
  },

  "commands": {
    "auto-print": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y"
      },
      "description": "Clean and print"
    },
    "undo-print": {
      "suggested_key": {
        "default": "Ctrl+Shift+U"
      },
      "description": "Undo clean"
    },
    "detail-information": {
      "suggested_key": {
        "default": "Ctrl+Shift+H"
      },
      "description": "Show/Hide information"
    }
  },
  
  "host_permissions": [
    "https://seller-id.tokopedia.com/*",
    "https://seller.shopee.co.id/*"
  ]
}